def format_table(headers, rows):
    """
    Prints a simple ASCII table without prettytable dependency.
    """
    if not rows:
        return

    # Calculate column widths
    col_widths = [len(str(h)) for h in headers]

    for row in rows:
        for i, val in enumerate(row):
            str_val = str(val) if val is not None else ""
            if i < len(col_widths):
                col_widths[i] = max(col_widths[i], len(str_val))

    # Create separator line
    separator = "+" + "+".join("-" * (w + 2) for w in col_widths) + "+"

    # Print Header
    header_row = "|" + "|".join(f" {str(h).ljust(col_widths[i])} " for i, h in enumerate(headers)) + "|"
    print(separator)
    print(header_row)
    print(separator)

    # Print Rows
    for row in rows:
        row_str = "|" + "|".join(f" {str(val).ljust(col_widths[i])} " for i, val in enumerate(row)) + "|"
        print(row_str)

    print(separator)

######################################################################
# MAIN
######################################################################

# Quick exit: no enclosures present
if not enclosures_exist():
    print("No enclosure detected.")
    sys.exit(0)

Debug("=== START MAIN EXECUTION ===")

map_lsblk = parse_lsblk_disks()
Debug("Parsed lsblk disks", {"count": len(map_lsblk), "devices": list(map_lsblk.keys())})

map_lsscsi = parse_lsscsi_disks()
Debug("Parsed lsscsi disks", {"count": len(map_lsscsi), "devices": list(map_lsscsi.keys())})

Debug("Augmenting lsblk data with lsscsi metadata...")
for sd_dev, d in map_lsscsi.items():
    if sd_dev not in map_lsblk:
        continue
    map_lsblk[sd_dev]["sg_dev"] = d["sg_dev"]
    map_lsblk[sd_dev]["hctl"] = d["hctl"]
    map_lsblk[sd_dev]["lsscsi_wwn"] = d["sas_wwn"]

Debug("Augmentation complete")

Debug("Mapping enclosures...")
enclosures = map_enclosures()
Debug("Enclosures mapped", {"count": len(enclosures)})

Debug("Mapping enclosure slots via SES...")
slotmap = map_enclosure_slots(enclosures)
Debug("SES slotmap generated", {"count": len(slotmap)})

Debug("Loading sysfs SG->Enclosure mapping...")
sg_to_enc = map_sg_to_enclosure()

Debug("Loading sysfs Enclosure->Slot mapping...")
enc_slot_map = map_enclosure_slots_sysfs()

Debug("Mapping enclosure slots onto devices & collecting all slots...")

all_slots = []
for enc_wwn, enc in enclosures.items():
    alias = enc["alias"]
    sg_dev = enc["sg_dev"]
    enc_hctl = enc.get("hctl", "")
    num_slots = enc["num_slots"]
    ses_slots = slotmap.get(sg_dev, {})

    for s in range(num_slots):
        s_str = str(s)
        ses_wwn = ses_slots.get(s_str, "EMPTY")
        all_slots.append({
            "alias": alias,
            "sg_dev": sg_dev,
            "hctl": enc_hctl,
            "slot": s_str,
            "ses_wwn": ses_wwn,
            "drive_wwn": None,
            "drive_data": None,
            "matched_by": None
        })

# 2. First Pass: Match drives to slots using SES WWN
for slot_info in all_slots:
    if slot_info["ses_wwn"] == "EMPTY":
        continue
    ses_wwn = slot_info["ses_wwn"]
    ses_wwn_int = int(ses_wwn, 16)

    for sd_dev, d in map_lsblk.items():
        if slot_info["drive_wwn"]:
            continue
        drive_wwn = d.get("WWN", "")
        if not drive_wwn:
            continue

        diff = abs(int(drive_wwn, 16) - ses_wwn_int)
        if diff <= 2:
            slot_info["drive_wwn"] = drive_wwn
            slot_info["drive_data"] = d
            slot_info["matched_by"] = "wwn"
            break

# 3. Second Pass: HCTL Bus Fallback
for sd_dev, d in map_lsblk.items():
    if any(sl["drive_wwn"] == d.get("WWN", "") for sl in all_slots):
        continue 
    if "backplane" in d:
        continue

    drive_hctl = d.get("hctl", "")
    if not drive_hctl:
        continue

    parts = drive_hctl.split(":")
    drive_bus = ":".join(parts[:3]) if len(parts) >= 3 else drive_hctl

    for slot_info in all_slots:
        if slot_info["drive_wwn"]:
            continue 

        enc_bus = ":".join(slot_info["hctl"].split(":")[:3]) if slot_info["hctl"] else ""
        if drive_bus == enc_bus:
            slot_info["drive_wwn"] = d.get("WWN", "")
            slot_info["drive_data"] = d
            slot_info["matched_by"] = "hctl"
            break

# 4. Third Pass: Sysfs Fallback
for enc_wwn, enc in enclosures.items():
    sg_dev = enc["sg_dev"]
    sysfs_enc = sg_to_enc.get(sg_dev)
    if not sysfs_enc or sysfs_enc not in enc_slot_map:
        continue

    for s in sorted(enc_slot_map[sysfs_enc].keys()):
        dev = enc_slot_map[sysfs_enc][s]
        if dev not in map_lsblk:
            continue
        d = map_lsblk[dev]
        dev_wwn = d.get("WWN", "")

        for slot in all_slots:
            if slot["alias"] == enc["alias"] and not slot["drive_wwn"]:
                already_matched = any(sl["drive_wwn"] == dev_wwn for sl in all_slots)
                if not already_matched:
                    slot["drive_wwn"] = dev_wwn
                    slot["drive_data"] = d
                    slot["matched_by"] = "sysfs"
                    break

for slot_info in all_slots:
    if slot_info["drive_data"]:
        d = slot_info["drive_data"]
        d["backplane"] = slot_info["sg_dev"]
        d["slot"] = slot_info["slot"]
        d["bp_alias"] = slot_info["alias"]

Debug("Slot mapping complete")

Debug("Aggregating physical disks...")
physical_disks = aggregate_physical_disks(map_lsblk)
Debug("Physical disks aggregated", {"count": len(physical_disks)})

Debug("Generating RID and Locate data...")

multipath_active = is_multipath_enabled()
Debug("multipath_active = " + str(multipath_active))

if multipath_active:
    map_dev_to_rid = map_Dev_to_RID(True)
else:
    map_dev_to_rid = map_Dev_to_RID(False)

Debug("RID map generated", {"count": len(map_dev_to_rid)})

Debug("Generating output table...")
output = []

headers = [
    "Backplane",
    "Slot",
    "Dev",
    "Vendor",
    "Model",
    "Serial",
    "Firmware",
    "Media",
    "Size",
    "Rid",
    "Locate",
]

for s in all_slots:
    slot_str = s["slot"]
    alias_bp = s["alias"]
    sg_dev = s["sg_dev"]

    disk_data = None
    if s["drive_wwn"]:
        if s["drive_wwn"] in physical_disks:
            disk_data = physical_disks[s["drive_wwn"]]
        else:
            disk_data = s["drive_data"]
    else:
        disk_data = s["drive_data"]

    if disk_data:
        devs = ",".join(sorted(disk_data.get("DEVICES", [])))
        if not devs:
             devs = s["drive_wwn"] or "-"

        vendor = str(disk_data.get("VENDOR", "")).strip()
        model = str(disk_data.get("MODEL", "")).strip()
        serial = str(disk_data.get("SERIAL", "")).strip()
        firmware = str(disk_data.get("REV", "")).strip()

        rota = str(disk_data.get("ROTA", "")).strip()
        rota_txt = {"1": "hd", "0": "ssd"}.get(rota, "unknown")
        media = "disk:" + rota_txt

        h_vendor = HumanFriendlyVendor(vendor, model)
        h_model = HumanFriendlyModel(vendor, model)
        h_serial = HumanFriendlySerial(serial, vendor, model)

        # --- Calculate True Physical Size from /sys/block ---
        # We use the first device in the DEVICES list, assuming it's the primary block device (e.g. sda)
        primary_dev = devs.split(",")[0] if devs and devs != "-" else None
        size = "-"

        if primary_dev:
            # Remove /dev/ prefix if present for sysfs path
            clean_dev = primary_dev.replace("/dev/", "")
            # Verify it exists in /sys/block to avoid errors on virtual/mapper devices if needed,
            # though get_physical_size_bytes handles errors gracefully.
            if os.path.exists(f"/sys/block/{clean_dev}"):
                total_bytes = get_physical_size_bytes(primary_dev)
                if total_bytes:
                    size = HumanFriendlySizeBytes(total_bytes)

        # --- RID Logic ---
        # CHECK ALL ASSOCIATED BLOCK DEVICES FOR A RID
        rid = "UNKNOWN"

        # 1. Check the aggregated devices list (includes /dev/sd* and potentially /dev/mapper/mpath*)
        if devs and devs != "-":
            device_list = [d.strip() for d in devs.split(",")]
            for check_dev in device_list:
                if check_dev in map_dev_to_rid:
                    rid = map_dev_to_rid[check_dev]
                    # Use this device as the primary display if found, as it's likely the preferred path
                    primary_dev = check_dev
                    break

        # 2. Fallback: Check the drive WWN directly in the map (for legacy or specific mappings)
        if rid == "UNKNOWN" and s["drive_wwn"] and s["drive_wwn"] in map_dev_to_rid:
            rid = map_dev_to_rid[s["drive_wwn"]]

        # --- Locate LED Logic ---
        locate = "UNKNOWN"
        if sg_dev and slot_str:
            locate = GetLocateLEDState_safe(sg_dev, slot_str)

    else:
        devs = "-"
        h_vendor = "-"
        h_model = "-"
        h_serial = "-"
        firmware = "-"
        media = "-"
        size = "-"
        rota_txt = "-"
        rid = "-"
        locate = "-"

    output.append([
        alias_bp,
        slot_str,
        devs,
        h_vendor,
        h_model,
        h_serial,
        firmware,
        media,
        size,
        rid,
        locate,
    ])

# Sort the output
output.sort(key=lambda r: (
    0 if r[0] == "Direct" else 1,
    r[0],
    int(r[1]) if r[1] != "-" else 999999
))

Debug("Output table generation complete", {"rows": len(output)})
format_table(headers, output)
Debug("=== END MAIN EXECUTION ===")
