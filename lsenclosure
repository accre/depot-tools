#!/usr/bin/env python3

"""
lsenclosure - List block devices attached to a storage backplane
"""

import re
import os
import sys
import time

from subprocess import Popen, PIPE, STDOUT
from shutil import which

_CACHE = {}

PRINT_DEBUG = False

def Debug(*args):
    """Accepts one or more arguments. Prints dicts key-by-value, others as strings."""
    if not PRINT_DEBUG:
        return
    for arg in args:
        if isinstance(arg, dict):
            for k in arg.keys():
                print("DEBUG: " + str(k) + " - " + str(arg[k]))
        else:
            print("DEBUG: " + str(arg))


def SysExec(cmd):
    CACHE_TTL = 20
    now = time.time()
    if cmd in _CACHE and now - _CACHE[cmd][0] < CACHE_TTL:
        return _CACHE[cmd][1]
    result = Popen(cmd.split(), stdout=PIPE, stderr=STDOUT).communicate()[0]
    if isinstance(result, bytes):
        result = result.decode("utf-8")
    _CACHE[cmd] = (now, result)
    return result


def Bin_Requires(bin):
    bin_path = which(bin)
    if not bin_path:
        print("ERROR: Could not locate " + bin + " in the PATH")
        sys.exit(1)
    return bin_path


# Check for required binaries
for bin in ("sg_ses", "sg_vpd", "lsblk", "lsscsi"):
    Bin_Requires(bin)


# ------------------------------------------------------------------
# Enclosure Detection
# ------------------------------------------------------------------

def enclosures_exist():
    """
    Check whether any storage enclosures are present.

    Method 1 – lsscsi -g | grep enclos
    Method 2 – scan /sys/class/enclosure
    """
    # Method 1: lsscsi -g (pipe handled in Python, not via shell)
    lsscsi_bin = which("lsscsi")
    if lsscsi_bin:
        try:
            out = SysExec("lsscsi -g")
            if re.search(r'enclos', out, re.IGNORECASE):
                Debug("Enclosure detected via lsscsi")
                return True
        except Exception:
            pass

    # Method 2: sysfs
    enc_root = "/sys/class/enclosure"
    if os.path.isdir(enc_root):
        try:
            entries = os.listdir(enc_root)
            if entries:
                Debug("Enclosure detected via sysfs:", entries)
                return True
        except OSError:
            pass

    return False


