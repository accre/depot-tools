"""
lsenclosure - List block devices attached to a storage backplane
"""

import re
import os
import sys
import time

from subprocess import Popen, PIPE, STDOUT
from shutil import which

# ------------------------------------------------------------------
# Dependency Check
# ------------------------------------------------------------------
try:
    from prettytable import PrettyTable
except ImportError:
    print("ERROR: Python module 'prettytable' is not installed.")
    print("Please install it using: pip3 install prettytable")
    sys.exit(1)

# Cache info
_CACHE = {}

PRINT_DEBUG = False

def Debug(*args):
    """Accepts one or more arguments. Prints dicts key-by-value, others as strings."""
    if not PRINT_DEBUG:
        return
    for arg in args:
        if isinstance(arg, dict):
            for k in arg.keys():
                print("DEBUG: " + str(k) + " - " + str(arg[k]))
        else:
            print("DEBUG: " + str(arg))


def SysExec(cmd):
    CACHE_TTL = 20
    now = time.time()
    if cmd in _CACHE and now - _CACHE[cmd][0] < CACHE_TTL:
        return _CACHE[cmd][1]
    result = Popen(cmd.split(), stdout=PIPE, stderr=STDOUT).communicate()[0]
    if isinstance(result, bytes):
        result = result.decode("utf-8")
    _CACHE[cmd] = (now, result)
    return result


def Bin_Requires(bin):
    bin_path = which(bin)
    if not bin_path:
        print("ERROR: Could not locate " + bin + " in the PATH")
        sys.exit(1)
    return bin_path


for bin in ("sg_ses", "sg_vpd", "lsblk", "lsscsi"):
    Bin_Requires(bin)


######################################################################
# PARSERS
######################################################################


def parse_lsblk():
    Debug("ENTER: parse_lsblk")
    m = {}

    for line in SysExec("lsblk -O -P").splitlines():

        keyval = dict(
            re.findall(
                r'(\w+)="([^"]+)"',
                re.sub("-", "_", line)
            )
        )

        name = keyval["NAME"]
        del keyval["NAME"]

        if re.search("loop", name):
            continue

        m["/dev/" + name] = keyval

    Debug("EXIT: parse_lsblk", {"count": len(m), "sample_keys": list(m.keys())[:3]})
    return m


def parse_lsblk_disks():
    Debug("ENTER: parse_lsblk_disks")
    raw = parse_lsblk()

    disks = {}

    for k in raw.keys():

        if raw[k]["TYPE"] != "disk":
            continue

        if "HCTL" not in raw[k]:
            continue

        disks[k] = raw[k]

    Debug("EXIT: parse_lsblk_disks", {"count": len(disks)})
    return disks


def parse_lsscsi():
    Debug("ENTER: parse_lsscsi")
    m = {}

    c = 0

    for line in SysExec("lsscsi -gUN").splitlines():

        line = " ".join(line.split())

        fields = line.split()
        hctl = fields[0].strip("[]")
        type_ = fields[1]
        sas_wwn = fields[2]
        sd_dev = fields[3]
        sg_dev = fields[4]

        if sd_dev == "-":
            sd_dev = "/dev/null" + str(c)
            c += 1

        m[sd_dev] = {
            "sg_dev": sg_dev,
            "hctl": hctl,
            "sas_wwn": sas_wwn,
            "type": type_,
        }

    Debug("EXIT: parse_lsscsi", {"count": len(m)})
    return m


def parse_lsscsi_disks():
    Debug("ENTER: parse_lsscsi_disks")
    raw = parse_lsscsi()

    out = {}

    for k in raw.keys():

        if raw[k]["type"] != "disk":
            continue

        out[k] = raw[k]

    Debug("EXIT: parse_lsscsi_disks", {"count": len(out)})
    return out


def parse_lsscsi_enclosures():
    Debug("ENTER: parse_lsscsi_enclosures")
    raw = parse_lsscsi()

    out = {}

    for k in raw.keys():

        if raw[k]["type"] != "enclosu":
            continue

        out[k] = raw[k]

    Debug("EXIT: parse_lsscsi_enclosures", {"count": len(out)})
    return out


######################################################################
# WWN AGGREGATION
######################################################################


def aggregate_physical_disks(map_lsblk):
    Debug("ENTER: aggregate_physical_disks")
    """
    Group all paths to the same physical disk by WWN.
    """

    physical = {}

    for sd_dev, d in map_lsblk.items():

        wwn = d.get("WWN", "") or sd_dev

        if wwn not in physical:

            physical[wwn] = {**d, "DEVICES": [sd_dev], "SG_DEVICES": []}

            if "sg_dev" in d:
                physical[wwn]["SG_DEVICES"].append(d["sg_dev"])

        else:

            physical[wwn]["DEVICES"].append(sd_dev)

            if "sg_dev" in d:
                physical[wwn]["SG_DEVICES"].append(d["sg_dev"])

            #
            # Prefer entries with enclosure data
            #
            for key in ("slot", "backplane", "bp_alias"):
                if key in d:
                    physical[wwn][key] = d[key]

    Debug("EXIT: aggregate_physical_disks", {"count": len(physical)})
    return physical


######################################################################
# ENCLOSURE HANDLING
######################################################################

def map_enclosures():
    Debug("ENTER: map_enclosures")
    raw = parse_lsscsi_enclosures()

    dedup = {}
    
    # Counter to ensure unique suffixes if multiple backplanes share similar traits
    # We'll assign unique IDs based on the order they appear in 'raw'
    enclosure_index = 0

    for sd_dev, d in raw.items():
        wwn = d["sas_wwn"]

        if wwn in dedup:
            continue

        sg_dev = d["sg_dev"]

        dedup[wwn] = dict(d)

        # Determine slot count ONLY for Array device slots
        ses_output = SysExec("sg_ses -p aes " + str(sg_dev))
        lines = ses_output.splitlines()

        current_element_type = ""
        num_slots = 0
        drive_slot_indices = []

        for line in lines:
            if "Element type:" in line:
                parts = line.split(":", 1)
                if len(parts) > 1:
                    current_element_type = parts[1].strip()
                continue

            if "Element index:" in line:
                if "Array device slot" in current_element_type:
                    try:
                        idx_part = line.split(":")[1].strip()
                        idx_str = idx_part.split()[0]
                        num_slots += 1
                        drive_slot_indices.append(int(idx_str))
                    except (ValueError, IndexError):
                        pass

        dedup[wwn]["num_slots"] = num_slots
        dedup[wwn]["drive_slot_indices"] = drive_slot_indices
        dedup[wwn]["sg_dev"] = sg_dev # Ensure sg_dev is stored in dedup

        # Assign Base Alias
        base_alias = "Unknown"
        if num_slots == 31:
            base_alias = "Valiant"
        elif num_slots == 24:
            base_alias = "Back"
        elif num_slots == 12:
            base_alias = "Front"
        elif num_slots == 36:
            base_alias = "Unified"
        elif num_slots == 30:
             base_alias = "Valiant" # Fallback for the other Valiant backplane

        # Make Unique: Append index to the alias
        # Example: "Valiant_1", "Valiant_2"
        unique_alias = f"{base_alias}_{enclosure_index + 1}"
        dedup[wwn]["alias"] = unique_alias
        
        enclosure_index += 1

    Debug("EXIT: map_enclosures", {"count": len(dedup), "wwns": list(dedup.keys()), "aliases": {k: v['alias'] for k, v in dedup.items()}})
    return dedup


def map_enclosure_slots(enclosures):
    Debug("ENTER: map_enclosure_slots")
    slotmap = {}

    for enc_wwn, enc in enclosures.items():

        sg_dev = enc["sg_dev"]

        slotmap[sg_dev] = {}

        slot = ""
        sas_wwn = ""

        for line in SysExec("sg_ses -p aes " + str(sg_dev)).splitlines():

            if re.search("Element type: SAS expander", line):
                break

            if not re.search(
                "(Element index:|SAS address|target port for:)",
                line
            ):
                continue

            if re.search("attached SAS address", line):
                continue

            if re.search("Element index:", line):

                slot = line.split(":")[1].split()[0]

            if re.search("SAS address", line):

                sas_wwn = line.split(":")[1].strip()

                if sas_wwn == "0x0":
                    sas_wwn = "EMPTY"

                slotmap[sg_dev][slot] = sas_wwn

    Debug("EXIT: map_enclosure_slots", {"sg_devs": list(slotmap.keys()), "sample_slots": {k: list(v.keys())[:3] for k, v in slotmap.items()}})
    return slotmap


# ------------------------------------------------------------------
# Sysfs Fallback Mappers
# ------------------------------------------------------------------

def map_sg_to_enclosure():
    Debug("ENTER: map_sg_to_enclosure")
    """
    Map /dev/sgX devices to Linux sysfs enclosure names.
    """
    mapping = {}
    enclosure_root = "/sys/class/enclosure"
    if not os.path.isdir(enclosure_root):
        Debug("EXIT: map_sg_to_enclosure (no enclosure root)", mapping)
        return mapping

    for enc_name in os.listdir(enclosure_root):
        enc_path = os.path.realpath(os.path.join(enclosure_root, enc_name))
        enc_parent = os.path.dirname(os.path.dirname(enc_path))
        
        for sg in os.listdir("/sys/class/scsi_generic"):
            sg_path = os.path.realpath(f"/sys/class/scsi_generic/{sg}/device")
            if sg_path == enc_parent:
                mapping[f"/dev/{sg}"] = enc_name
                
    Debug("EXIT: map_sg_to_enclosure", mapping)
    return mapping


def map_enclosure_slots_sysfs():
    Debug("ENTER: map_enclosure_slots_sysfs")
    """
    Map Linux sysfs enclosure names to slot -> /dev/sdX mappings.
    Handles SATA drives that SES often reports as empty/0x0.
    """
    mapping = {}
    enclosure_root = "/sys/class/enclosure"
    if not os.path.isdir(enclosure_root):
        Debug("EXIT: map_enclosure_slots_sysfs (no enclosure root)", mapping)
        return mapping

    for enc_name in os.listdir(enclosure_root):
        enc_path = os.path.join(enclosure_root, enc_name)
        mapping[enc_name] = {}
        
        try:
            slot_entries = os.listdir(enc_path)
        except OSError:
            continue
            
        for slot_name in slot_entries:
            slot_path = os.path.join(enc_path, slot_name)
            if not os.path.isdir(slot_path):
                continue
                
            block_dir = os.path.join(slot_path, "device", "block")
            if not os.path.isdir(block_dir):
                continue
                
            try:
                devices = os.listdir(block_dir)
            except OSError:
                continue
                
            if not devices:
                continue
                
            dev = "/dev/" + devices[0]
            slot_match = re.search(r"(\d+)", slot_name)
            if not slot_match:
                continue
                
            mapping[enc_name][int(slot_match.group(1))] = dev
            
    Debug("EXIT: map_enclosure_slots_sysfs", mapping)
    return mapping


######################################################################
# HUMAN FRIENDLY
######################################################################


def HumanFriendlyVendor(Vendor, Model):
    Debug("ENTER: HumanFriendlyVendor", {"Vendor": Vendor, "Model": Model})
    Vendor = re.sub("_", " ", Vendor)
    Model = re.sub("_", " ", Model)

    if re.search("INTEL", Model):
        out = "Intel"
        Debug("EXIT: HumanFriendlyVendor", {"result": out})
        return out

    if re.search("Hitachi", Model):
        out = "Hitachi"
        Debug("EXIT: HumanFriendlyVendor", {"result": out})
        return out

    if re.search("TOSHIBA", Vendor):
        out = "Toshiba"
        Debug("EXIT: HumanFriendlyVendor", {"result": out})
        return out

    if Vendor.startswith("ST") or Model.startswith("ST"):
        out = "Seagate"
        Debug("EXIT: HumanFriendlyVendor", {"result": out})
        return out

    out = Vendor.strip()
    Debug("EXIT: HumanFriendlyVendor", {"result": out})
    return out

def HumanFriendlyModel(Vendor, Model):
    Debug("ENTER: HumanFriendlyModel", {"Vendor": Vendor, "Model": Model})
    Vendor = re.sub("_", " ", Vendor)
    Model = re.sub("_", " ", Model)

    if Model.startswith("ST"):
        out = Model
        Debug("EXIT: HumanFriendlyModel", {"result": out})
        return out

    if re.search("INTEL_", Model):  # Fixed typo: model -> Model
        out = Model.replace("INTEL_", "")
        Debug("EXIT: HumanFriendlyModel", {"result": out})
        return out

    if re.search("Hitachi", Model):
        out = Model.replace("Hitachi ", "")
        Debug("EXIT: HumanFriendlyModel", {"result": out})
        return out

    out = Model.strip()
    Debug("EXIT: HumanFriendlyModel", {"result": out})
    return out


def HumanFriendlySerial(Serial, Vendor, Model):
    Debug("ENTER: HumanFriendlySerial", {"Serial": Serial, "Vendor": Vendor})
    Serial = Serial.strip()

    if Vendor == "SEAGATE":
        Serial = Serial[:8]

#    if re.search("Hitachi", Model):

    if not Serial:
        out = "NO_SERIAL"
        Debug("EXIT: HumanFriendlySerial", {"result": out})
        return out

    out = Serial
    Debug("EXIT: HumanFriendlySerial", {"result": out})
    return out


######################################################################
# MAIN
######################################################################

Debug("=== START MAIN EXECUTION ===")

map_lsblk = parse_lsblk_disks()
Debug("Parsed lsblk disks", {"count": len(map_lsblk), "devices": list(map_lsblk.keys())})

map_lsscsi = parse_lsscsi_disks()
Debug("Parsed lsscsi disks", {"count": len(map_lsscsi), "devices": list(map_lsscsi.keys())})

#
# Augment lsblk data
#
Debug("Augmenting lsblk data with lsscsi metadata...")
for sd_dev, d in map_lsscsi.items():

    if sd_dev not in map_lsblk:
        continue

    map_lsblk[sd_dev]["sg_dev"] = d["sg_dev"]
    map_lsblk[sd_dev]["hctl"] = d["hctl"]
    map_lsblk[sd_dev]["lsscsi_wwn"] = d["sas_wwn"]

Debug("Augmentation complete")

#
# Map enclosures
#
Debug("Mapping enclosures...")
enclosures = map_enclosures()
Debug("Enclosures mapped", {"count": len(enclosures)})

Debug("Mapping enclosure slots via SES...")
slotmap = map_enclosure_slots(enclosures)
Debug("SES slotmap generated", {"count": len(slotmap)})

# NEW: Load sysfs fallback mappings for SATA/unmapped drives
Debug("Loading sysfs SG->Enclosure mapping...")
sg_to_enc = map_sg_to_enclosure()

Debug("Loading sysfs Enclosure->Slot mapping...")
enc_slot_map = map_enclosure_slots_sysfs()

#
# Map enclosure slots onto sd devices (Enhanced)
#
######################################################################
# ROBUST SLOT MAPPING & OUTPUT
######################################################################

Debug("Mapping enclosure slots onto devices & collecting all slots...")

# 1. Build a complete list of all expected slots across all enclosures
all_slots = []
for enc_wwn, enc in enclosures.items():
    alias = enc["alias"]
    sg_dev = enc["sg_dev"]
    enc_hctl = enc.get("hctl", "")
    num_slots = enc["num_slots"]
    ses_slots = slotmap.get(sg_dev, {})

    for s in range(num_slots):
        s_str = str(s)
        ses_wwn = ses_slots.get(s_str, "EMPTY")
        all_slots.append({
            "alias": alias,
            "sg_dev": sg_dev,
            "hctl": enc_hctl,
            "slot": s_str,
            "ses_wwn": ses_wwn,
            "drive_wwn": None,
            "drive_data": None,
            "matched_by": None
        })

# 2. First Pass: Match drives to slots using SES WWN (±2 heuristic)
for slot_info in all_slots:
    if slot_info["ses_wwn"] == "EMPTY":
        continue
    ses_wwn = slot_info["ses_wwn"]
    ses_wwn_int = int(ses_wwn, 16)

    for sd_dev, d in map_lsblk.items():
        if slot_info["drive_wwn"]:
            continue
        drive_wwn = d.get("WWN", "")
        if not drive_wwn:
            continue

        diff = abs(int(drive_wwn, 16) - ses_wwn_int)
        if diff <= 2:
            slot_info["drive_wwn"] = drive_wwn
            slot_info["drive_data"] = d
            slot_info["matched_by"] = "wwn"
            break

# 3. Second Pass: HCTL Bus Fallback for unmapped drives
# Catches drives that `sg_ses` doesn't report but share the same SCSI bus as the backplane
for sd_dev, d in map_lsblk.items():
    if any(sl["drive_wwn"] == d.get("WWN", "") for sl in all_slots):
        continue # Already matched
    if "backplane" in d:
        continue

    drive_hctl = d.get("hctl", "")
    if not drive_hctl:
        continue

    parts = drive_hctl.split(":")
    drive_bus = ":".join(parts[:3]) if len(parts) >= 3 else drive_hctl

    for slot_info in all_slots:
        if slot_info["drive_wwn"]:
            continue # Slot already taken

        enc_bus = ":".join(slot_info["hctl"].split(":")[:3]) if slot_info["hctl"] else ""
        if drive_bus == enc_bus:
            slot_info["drive_wwn"] = d.get("WWN", "")
            slot_info["drive_data"] = d
            slot_info["matched_by"] = "hctl"
            break

# 4. Third Pass: Sysfs Fallback (handles SATA drives where SES reports 0x0)
for enc_wwn, enc in enclosures.items():
    sg_dev = enc["sg_dev"]
    sysfs_enc = sg_to_enc.get(sg_dev)
    if not sysfs_enc or sysfs_enc not in enc_slot_map:
        continue

    for s in sorted(enc_slot_map[sysfs_enc].keys()):
        dev = enc_slot_map[sysfs_enc][s]
        if dev not in map_lsblk:
            continue
        d = map_lsblk[dev]
        dev_wwn = d.get("WWN", "")

        for slot in all_slots:
            if slot["alias"] == enc["alias"] and not slot["drive_wwn"]:
                already_matched = any(sl["drive_wwn"] == dev_wwn for sl in all_slots)
                if not already_matched:
                    slot["drive_wwn"] = dev_wwn
                    slot["drive_data"] = d
                    slot["matched_by"] = "sysfs"
                    break

# Apply matches back to map_lsblk for the aggregation step
for slot_info in all_slots:
    if slot_info["drive_data"]:
        d = slot_info["drive_data"]
        d["backplane"] = slot_info["sg_dev"]
        d["slot"] = slot_info["slot"]
        d["bp_alias"] = slot_info["alias"]

Debug("Slot mapping complete")

# Collapse multiple sd devices into physical disks
Debug("Aggregating physical disks...")
physical_disks = aggregate_physical_disks(map_lsblk)
Debug("Physical disks aggregated", {"count": len(physical_disks)})

######################################################################
# OUTPUT
######################################################################

Debug("Generating output table...")
output = []

for s in all_slots:
    slot_str = s["slot"]
    alias_bp = s["alias"]
    
    # Retrieve data from aggregated physical_disks if possible, else fallback to raw mapping
    disk_data = physical_disks.get(s["drive_wwn"], s["drive_data"]) if s["drive_wwn"] else s["drive_data"]
    
    if disk_data:
        devs = ",".join(sorted(disk_data.get("DEVICES", [s["drive_wwn"]])))
        vendor = str(disk_data.get("VENDOR", "")).strip()
        model = str(disk_data.get("MODEL", "")).strip()
        serial = str(disk_data.get("SERIAL", "")).strip()
        firmware = str(disk_data.get("REV", "")).strip()
        size = str(disk_data.get("SIZE", "")).strip()
        rota = str(disk_data.get("ROTA", "")).strip()
        rota_txt = {"1": "hd", "0": "ssd"}.get(rota, "unknown")
        media = "disk:" + rota_txt

        h_vendor = HumanFriendlyVendor(vendor, model)
        h_model = HumanFriendlyModel(vendor, model)
        h_serial = HumanFriendlySerial(serial, vendor, model)
    else:
        # Empty slot formatting
        devs = "-"
        h_vendor = "-"
        h_model = "-"
        h_serial = "-"
        firmware = "-"
        media = "-"
        size = "-"
        rota_txt = "-"

    output.append([
        alias_bp,
        slot_str,
        devs,
        h_vendor,
        h_model,
        h_serial,
        firmware,
        media,
        size,
    ])

x = PrettyTable([
    "Backplane",
    "Slot",
    "Dev",
    "Vendor",
    "Model",
    "Serial",
    "Firmware",
    "Media",
    "Size",
])

x.padding_width = 1
x.align = "l"

# Sort: Direct first, then by backplane alias, then numerically by slot
output.sort(key=lambda r: (
    0 if r[0] == "Direct" else 1, 
    r[0], 
    int(r[1]) if r[1] != "-" else 999999
))

for row in output:
    x.add_row(row)

Debug("Output table generation complete", {"rows": len(output)})
print(x)
Debug("=== END MAIN EXECUTION ===")
