def HumanFriendlyVendor(Vendor, Model):
    Vendor = re.sub("_", " ", Vendor)
    Model = re.sub("_", " ", Model)

    if re.search("INTEL", Model):
        return "Intel"
    if re.search("Hitachi", Model):
        return "Hitachi"
    if re.search("TOSHIBA", Vendor):
        return "Toshiba"
    if Vendor.startswith("ST") or Model.startswith("ST"):
        return "Seagate"
    return Vendor.strip()

def HumanFriendlyModel(Vendor, Model):
    Vendor = re.sub("_", " ", Vendor)
    Model = re.sub("_", " ", Model)

    if Model.startswith("ST"):
        return Model
    if re.search("INTEL_", Model):
        return Model.replace("INTEL_", "")
    if re.search("Hitachi", Model):
        return Model.replace("Hitachi ", "")
    return Model.strip()


def HumanFriendlySerial(Serial, Vendor, Model):
    Serial = Serial.strip()
    if Vendor == "SEAGATE":
        Serial = Serial[:8]
    if not Serial:
        return "NO_SERIAL"
    return Serial

def get_physical_size_bytes(dev_name):
    """
    Reads /sys/block/<dev>/size and calculates total bytes.
    /sys/block/<dev>/size is the number of 512-byte sectors.
    """
    # Extract just the device name (e.g., 'sda' from '/dev/sda')
    dev_name = dev_name.replace("/dev/", "")

    sys_path = f"/sys/block/{dev_name}/size"

    try:
        with open(sys_path, 'r') as f:
            sectors = int(f.read().strip())
            return sectors * 512
    except (IOError, ValueError, OSError):
        return None

def HumanFriendlySizeBytes(total_bytes):
    """
    Convert total bytes to Base 10 (SI) string.
    """
    if total_bytes is None or total_bytes == 0:
        return "-"

    # Base 10 Multipliers
    if total_bytes >= 1000000000000: # TB
        return f"{total_bytes / 1000000000000:.1f} TB"
    elif total_bytes >= 1000000000: # GB
        return f"{total_bytes / 1000000000:.1f} GB"
    elif total_bytes >= 1000000: # MB
        return f"{total_bytes / 1000000:.1f} MB"
    elif total_bytes >= 1000: # KB
        return f"{total_bytes / 1000:.1f} KB"
    else:
        return f"{total_bytes:.0f} B"


