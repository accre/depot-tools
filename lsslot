#!/usr/bin/env python3

"""
lsslot - Mathew Binkley

Display a table showing which hard drive is in each slot on a depot.
"""

import os
import re
import shlex
import shutil
import subprocess
import time

from prettytable import PrettyTable

#############################################################################
# Globals
#############################################################################

CACHE_DATA = {}
CACHE_TIME = {}
CACHE_EXPIRES = 20

OUTPUT = []

PRINT_DEBUG = False

#############################################################################
# Utility Functions
#############################################################################


def debug(text):

    if PRINT_DEBUG:
        print(f"DEBUG: {text}")


def canonicalize_dev(dev):

    """
    Resolve symlinks/canonical device names safely.
    """

    try:

        real_dev = os.path.realpath(dev)

        if real_dev:
            return real_dev

    except OSError:
        pass

    return dev


def is_rotational_drive(dev):

    """
    Return True if the device is rotational.

    Linux exposes this via:
        /sys/block/<dev>/queue/rotational

    1 = HDD
    0 = SSD/NVMe/flash
    """

    try:

        base = os.path.basename(dev)

        rotational = sysexec(
            f"cat /sys/block/{base}/queue/rotational"
        ).strip()

        return rotational == "1"

    except Exception:

        return False


def normalize_sas_for_linux(sas_addr):

    """
    Normalize SES SAS addresses into Linux WWN form.

    SES and Linux often differ by small vendor-specific
    offsets.
    """

    try:

        if sas_addr.startswith("5000c"):

            #
            # Seagate-style:
            # Linux = SES + 2
            #
            return hex(
                int(sas_addr, 16) + 2
            ).split("x")[1].lower()

        if sas_addr.startswith("5000039"):

            #
            # HGST/Hitachi:
            # Linux = SES - 1
            #
            return hex(
                int(sas_addr, 16) - 1
            ).split("x")[1].lower()

    except ValueError:
        pass

    return sas_addr.lower()


def sysexec(cmd):

    """
    Execute a command and return stdout as a string.

    Results are cached for CACHE_EXPIRES seconds.
    """

    debug(f"sysexec(): {cmd}")

    if cmd in CACHE_DATA:
        if time.time() - CACHE_TIME[cmd] < CACHE_EXPIRES:
            return CACHE_DATA[cmd]

    try:
        parts = shlex.split(cmd)
    except ValueError as exc:
        debug(f"Invalid command: {exc}")
        return "ERROR"

    if not parts:
        return "ERROR"

    #
    # Special-case "cat file"
    #
    if len(parts) == 2 and parts[0] == "cat":

        try:
            with open(parts[1], "r", encoding="utf-8") as fh:
                output = fh.read()

        except OSError as exc:
            debug(f"Failed reading file: {exc}")
            output = "ERROR"

    else:

        try:
            result = subprocess.run(
                parts,
                capture_output=True,
                text=True,
                check=False,
            )

            output = result.stdout

        except OSError as exc:
            debug(f"Command failed: {exc}")
            output = "ERROR"

    CACHE_DATA[cmd] = output
    CACHE_TIME[cmd] = time.time()

    return output


def which(program):

    return shutil.which(program)


def require_binary(binary):

    if not which(binary):
        raise RuntimeError(
            f"Required executable not found: {binary}"
        )

#############################################################################
# Hardware Discovery
#############################################################################


def find_backplanes():

    debug("find_backplanes()")

    #
    # Systems without SES enclosures/backplanes
    #
    if not which("lsbackplane"):

        debug(
            "lsbackplane not found; "
            "no enclosures detected"
        )

        return {}

    backplanes = {}

    output = sysexec("lsbackplane")

    for line in output.splitlines():

        if "/dev/" not in line:
            continue

        fields = [x.strip() for x in line.split("|")]

        if len(fields) < 6:
            debug(f"Malformed lsbackplane line: {line}")
            continue

        enc_sg_dev = fields[1]

        backplanes[enc_sg_dev] = {
            "NumSlots": fields[2],
            "Bus": fields[3],
            "SASAddr": fields[4],
            "Alias": fields[5],
        }

    return backplanes


def get_sas_controller():

    debug("get_sas_controller()")

    output = sysexec("lspci")

    patterns = [
        (
            r"SAS2008 PCI-Express Fusion-MPT SAS-2 \[Falcon\]",
            "LSI_Falcon",
        ),
        (
            r"MegaRAID SAS 2208 \[Thunderbolt\]",
            "LSI_Thunderbolt",
        ),
        (
            r"MegaRAID SAS-3 3108 \[Invader\]",
            "LSI_Invader",
        ),
        (
            r"SAS3408 Fusion-MPT Tri-Mode",
            "LSI_FusionMPT",
        ),
        (
            r"Broadcom / LSI Fusion-MPT 12GSAS/PCIe Secure SAS38xx",
            "LSI_Fusion_12Gbs",
        ),
    ]

    for line in output.splitlines():

        for pattern, controller in patterns:

            if re.search(pattern, line):
                debug(f"SAS controller detected: {controller}")
                return controller

    return "Unknown"

#############################################################################
# LED State
#############################################################################


def get_locate_led_state(backplane, slot):

    output = sysexec(
        f"sg_ses -I {slot} --get=ident {backplane}"
    ).strip()

    if output == "1":
        return "On"

    if output == "0":
        return "Off"

    return "Unknown"

#############################################################################
# Mapping Functions
#############################################################################


def map_sas_to_dev():

    """
    Return map of Linux WWN/SAS -> /dev node
    """

    debug("map_sas_to_dev()")

    mapping = {}

    output_saslist = sysexec(
        "ls -alh /dev/disk/by-id"
    )

    for line in output_saslist.splitlines():

        if not re.search("wwn-", line):
            continue

        if re.search("part", line):
            continue

        try:

            this_dev = line.split()[-1]
            this_dev = this_dev.split("/")[-1]
            this_dev = "/dev/" + this_dev

            this_dev = canonicalize_dev(
                this_dev
            )

            this_sas = line.split()[-3]
            this_sas = this_sas.split("-")[1]
            this_sas = this_sas.split("x")[1]

            this_sas = this_sas.lower()

            debug(
                f"map_sas_to_dev(): "
                f"{this_sas} -> {this_dev}"
            )

            mapping[this_sas] = this_dev

        except Exception as exc:

            debug(
                f"map_sas_to_dev() parse failed: "
                f"{line} ({exc})"
            )

    return mapping


def map_sas_to_rid():

    """
    Return Linux WWN/SAS -> RID mapping.
    """

    debug("map_sas_to_rid()")

    mapping = {}

    #
    # Build dev -> RID map
    #
    dev_to_rid = {}

    output = sysexec(
        "ls -alh /dev/disk/by-label"
    )

    for line in output.splitlines():

        if "rid-data-" not in line:
            continue

        try:

            dev = line.split()[-1]
            dev = "/dev/" + dev.split("/")[-1]

            #
            # Strip partition suffix
            #
            dev = re.sub(
                r"[0-9]+$",
                "",
                dev,
            )

            dev = canonicalize_dev(dev)

            rid = line.split()[-3]
            rid = rid.split("-")[2]

            dev_to_rid[dev] = rid

            debug(
                f"RID map: "
                f"{dev} -> {rid}"
            )

        except Exception as exc:

            debug(
                f"RID parse failed: "
                f"{line} ({exc})"
            )

    #
    # Build SAS -> DEV map
    #
    sas_to_dev = map_sas_to_dev()

    #
    # Direct matches
    #
    for sas_addr, dev in sas_to_dev.items():

        if dev in dev_to_rid:

            mapping[sas_addr] = dev_to_rid[dev]

            debug(
                f"SAS direct map: "
                f"{sas_addr} -> "
                f"{dev_to_rid[dev]}"
            )

            continue

        #
        # Multipath fallback:
        # compare WWIDs
        #
        try:

            base = os.path.basename(dev)

            dev_wwid = sysexec(
                f"cat /sys/block/{base}/device/wwid"
            ).strip()

            if (
                not dev_wwid
                or dev_wwid == "ERROR"
            ):
                continue

            for candidate_dev, candidate_rid in (
                dev_to_rid.items()
            ):

                candidate_base = os.path.basename(
                    candidate_dev
                )

                candidate_wwid = sysexec(
                    f"cat /sys/block/{candidate_base}/device/wwid"
                ).strip()

                if (
                    not candidate_wwid
                    or candidate_wwid == "ERROR"
                ):
                    continue

                if dev_wwid == candidate_wwid:

                    mapping[sas_addr] = candidate_rid

                    debug(
                        f"SAS multipath map: "
                        f"{sas_addr} -> "
                        f"{candidate_rid} "
                        f"({dev} == "
                        f"{candidate_dev})"
                    )

                    break

        except Exception as exc:

            debug(
                f"Multipath compare failed: "
                f"{dev} ({exc})"
            )

    return mapping


def map_backplane_slot_to_sas(backplanes):

    """
    Return Backplane/Slot -> SES SAS map
    """

    debug("map_backplane_slot_to_sas()")

    mapping = {}

    for this_backplane in backplanes:

        mapping[this_backplane] = {}

        output_sgses = sysexec(
            f"sg_ses -p aes {this_backplane}"
        )

        val_slot = None
        val_sas = None

        for line in output_sgses.splitlines():

            if (
                not re.search(
                    "Element index:",
                    line
                )
                and not re.search(
                    "SAS address",
                    line
                )
            ):
                continue

            if re.search(
                "attached SAS address",
                line
            ):
                continue

            if re.search(
                "Element index:",
                line
            ):

                val_slot = line.split(":")[1]
                val_slot = val_slot.split(" ")[1]

            if re.search(
                "SAS address",
                line
            ):

                val_sas = line.split(":")[1]
                val_sas = re.sub(
                    " ",
                    "",
                    val_sas,
                )

                val_sas = re.sub(
                    "^0x",
                    "",
                    val_sas,
                ).lower()

            if val_slot and val_sas:

                debug(
                    f"{this_backplane} "
                    f"slot {val_slot} "
                    f"-> {val_sas}"
                )

                mapping[
                    this_backplane
                ][val_slot] = val_sas

                val_slot = None
                val_sas = None

    return mapping


def map_backplane_slot_to_dev(
    all_backplanes,
):

    """
    Return:
        backplane/slot -> dev
        backplane/slot -> sas
    """

    debug("map_backplane_slot_to_dev()")

    mapping = {}

    backplane_slot_to_sas = (
        map_backplane_slot_to_sas(all_backplanes)
    )

    #
    # Linux WWN -> device
    #
    linux_sas_to_dev = map_sas_to_dev()

    for backplane in all_backplanes:

        mapping[backplane] = {}

        all_slots = sorted(
            int(x)
            for x in (
                backplane_slot_to_sas
                .get(backplane, {})
                .keys()
            )
        )

        for slot in all_slots:

            dev = "Empty_Slot"

            ses_sas = (
                backplane_slot_to_sas
                .get(backplane, {})
                .get(str(slot))
            )

            if (
                ses_sas
                and ses_sas != "0"
            ):

                #
                # Normalize SES SAS into Linux WWN form
                #
                linux_sas = normalize_sas_for_linux(
                    ses_sas
                )

                if linux_sas in linux_sas_to_dev:

                    dev = linux_sas_to_dev[
                        linux_sas
                    ]

            mapping[backplane][slot] = dev

    return mapping, backplane_slot_to_sas

#############################################################################
# Main
#############################################################################


def main():

    get_sas_controller()

    backplane_list = find_backplanes()

    if not backplane_list:
        print("No enclosures detected.")
        return

    (
        backplane_slot_to_dev,
        backplane_slot_to_sas,
    ) = map_backplane_slot_to_dev(
        backplane_list,
    )

    sas_to_rid = map_sas_to_rid()

    linux_sas_to_dev = map_sas_to_dev()

    mapped_devices = set()

    #
    # Normal SES-visible slots
    #
    for backplane in backplane_list:

        alias = backplane_list[backplane]["Alias"]

        all_slots = sorted(
            int(x)
            for x in (
                backplane_slot_to_sas
                .get(backplane, {})
                .keys()
            )
        )

        for slot in all_slots:

            dev = (
                backplane_slot_to_dev
                .get(backplane, {})
                .get(slot, "Empty_Slot")
            )

            sas = (
                backplane_slot_to_sas
                .get(backplane, {})
                .get(str(slot))
            )

            rid = "Empty"

            if (
                sas
                and sas != "0"
            ):

                normalized_sas = (
                    normalize_sas_for_linux(
                        sas
                    )
                )

                if normalized_sas in sas_to_rid:

                    rid = sas_to_rid[
                        normalized_sas
                    ]

            #
            # Skip phantom SES elements
            #
            if (
                sas != "0"
                and dev == "Empty_Slot"
                and rid == "Empty"
            ):
                continue

            #
            # Track mapped devices
            #
            if dev != "Empty_Slot":
                mapped_devices.add(dev)

            #
            # Skip LED queries on empty bays
            #
            if sas == "0":

                led_state = "-"

            else:

                led_state = get_locate_led_state(
                    backplane,
                    slot,
                )

            OUTPUT.append([
                alias,
                str(slot),
                led_state,
                dev,
                rid,
            ])

    #
    # Add rotational Linux drives
    # not visible in SES
    #
    for sas_addr, dev in sorted(
        linux_sas_to_dev.items()
    ):

        #
        # Already mapped into enclosure
        #
        if dev in mapped_devices:
            continue

        #
        # Ignore SSD/NVMe/flash devices
        #
        if not is_rotational_drive(dev):

            debug(
                f"Skipping non-rotational "
                f"unmapped drive: {dev}"
            )

            continue

        rid = sas_to_rid.get(
            sas_addr,
            "Empty",
        )

        OUTPUT.append([
            "Unmapped",
            "?",
            "?",
            dev,
            rid,
        ])


    #
    # Remove duplicates and sort
    #
    output_unique = sorted(
        set(tuple(x) for x in OUTPUT)
    )

    table = PrettyTable([
        "Backplane",
        "Slot",
        "Locate LED",
        "Dev",
        "RID",
    ])

    table.padding_width = 1
    table.align = "l"

    for row in output_unique:
        table.add_row(row)

    print(table)


if __name__ == "__main__":
    main()
