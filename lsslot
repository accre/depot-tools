#!/usr/bin/env python3

"""
lsslot - Mathew Binkley

Display a table showing which hard drive is in each slot on a depot.
"""

import os
import re
import shlex
import shutil
import subprocess
import time

from prettytable import PrettyTable

#############################################################################
# Globals
#############################################################################

CACHE_DATA = {}
CACHE_TIME = {}
CACHE_EXPIRES = 20

OUTPUT = []

PRINT_DEBUG = False

#############################################################################
# Utility Functions
#############################################################################


def debug(text):

    if PRINT_DEBUG:
        print(f"DEBUG: {text}")


def canonicalize_dev(dev):

    """
    Resolve symlinks/canonical device names safely.
    """

    try:

        real_dev = os.path.realpath(dev)

        if real_dev:
            return real_dev

    except OSError:
        pass

    return dev


def is_rotational_drive(dev):

    """
    Return True if the device is rotational.

    Linux exposes this via:
        /sys/block/<dev>/queue/rotational

    1 = HDD
    0 = SSD/NVMe/flash
    """

    try:

        base = os.path.basename(dev)

        rotational = sysexec(f"cat /sys/block/{base}/queue/rotational").strip()

        return rotational == "1"

    except Exception:

        return False


def normalize_sas_for_linux(sas_addr):

    """
    Normalize SES SAS addresses into Linux WWN form.

    SES and Linux often differ by small vendor-specific
    offsets.
    """

    try:

        if sas_addr.startswith("5000c"):

            #
            # Seagate-style:
            # Linux = SES + 2
            #
            return hex(
                int(sas_addr, 16) + 2
            ).split("x")[1].lower()

        if sas_addr.startswith("5000039"):

            #
            # HGST/Hitachi:
            # Linux = SES - 1
            #
            return hex(
                int(sas_addr, 16) - 1
            ).split("x")[1].lower()

    except ValueError:
        pass

    return sas_addr.lower()


def sysexec(cmd):

    """
    Execute a command and return stdout as a string.

    Results are cached for CACHE_EXPIRES seconds.
    """

    debug(f"sysexec(): {cmd}")

    if cmd in CACHE_DATA:
        if time.time() - CACHE_TIME[cmd] < CACHE_EXPIRES:
            return CACHE_DATA[cmd]

    try:
        parts = shlex.split(cmd)
    except ValueError as exc:
        debug(f"Invalid command: {exc}")
        return "ERROR"

    if not parts:
        return "ERROR"

    #
    # Special-case "cat file"
    #
    if len(parts) == 2 and parts[0] == "cat":

        try:
            with open(parts[1], "r", encoding="utf-8") as fh:
                output = fh.read()

        except OSError as exc:
            debug(f"Failed reading file: {exc}")
            output = "ERROR"

    else:

        try:
            result = subprocess.run(
                parts,
                capture_output=True,
                text=True,
                check=False,
            )

            output = result.stdout

        except OSError as exc:
            debug(f"Command failed: {exc}")
            output = "ERROR"

    CACHE_DATA[cmd] = output
    CACHE_TIME[cmd] = time.time()

    return output


def which(program):

    return shutil.which(program)


def require_binary(binary):

    if not which(binary):
        raise RuntimeError(
            f"Required executable not found: {binary}"
        )

#############################################################################
# Hardware Discovery
#############################################################################


def find_backplanes():

    debug("find_backplanes()")

    require_binary("lsbackplane")

    backplanes = {}

    output = sysexec("lsbackplane")

    for line in output.splitlines():

        if "/dev/" not in line:
            continue

        fields = [x.strip() for x in line.split("|")]

        if len(fields) < 6:
            debug(f"Malformed lsbackplane line: {line}")
            continue

        enc_sg_dev = fields[1]

        backplanes[enc_sg_dev] = {
            "NumSlots": fields[2],
            "Bus": fields[3],
            "SASAddr": fields[4],
            "Alias": fields[5],
        }

    return backplanes


def get_sas_controller():

    debug("get_sas_controller()")

    output = sysexec("lspci")

    patterns = [
        (
            r"SAS2008 PCI-Express Fusion-MPT SAS-2 \[Falcon\]",
            "LSI_Falcon",
        ),
        (
            r"MegaRAID SAS 2208 \[Thunderbolt\]",
            "LSI_Thunderbolt",
        ),
        (
            r"MegaRAID SAS-3 3108 \[Invader\]",
            "LSI_Invader",
        ),
        (
            r"SAS3408 Fusion-MPT Tri-Mode",
            "LSI_FusionMPT",
        ),
        (
            r"Broadcom / LSI Fusion-MPT 12GSAS/PCIe Secure SAS38xx",
            "LSI_Fusion_12Gbs",
        ),
    ]

    for line in output.splitlines():

        for pattern, controller in patterns:

            if re.search(pattern, line):
                debug(f"SAS controller detected: {controller}")
                return controller

    return "Unknown"

def map_dev_to_rid():

    mapping = {}

    output = sysexec("ls -alh /dev/disk/by-label")

    for line in output.splitlines():

        if "rid-data-" not in line:
            continue

        try:

            dev = line.split()[-1]
            dev = "/dev/" + dev.split("/")[-1]

            dev = re.sub(
                r"[0-9]+$",
                "",
                dev,
            )

            dev = canonicalize_dev(dev)

            rid = line.split()[-3]
            rid = rid.split("-")[2]

            mapping[dev] = rid

        except Exception:
            pass

    return mapping

def map_enclosure_slot_to_dev():
    """
    Build a mapping from Linux enclosure slots to block devices.

    Returns:

        {
            enclosure_name: {
                slot_number: "/dev/sdX"
            }
        }

    Works for both SAS and SATA drives.
    """

    debug("map_enclosure_slot_to_dev()")

    mapping = {}

    enclosure_root = "/sys/class/enclosure"

    if not os.path.isdir(enclosure_root):
        return mapping

    for enclosure in os.listdir(enclosure_root):

        enclosure_path = os.path.join(
            enclosure_root,
            enclosure,
        )

        mapping[enclosure] = {}

        try:
            slot_entries = os.listdir(
                enclosure_path
            )

        except OSError:
            continue

        for slot_name in slot_entries:

            slot_path = os.path.join(
                enclosure_path,
                slot_name,
            )

            if not os.path.isdir(slot_path):
                continue

            #
            # Most kernels expose:
            #
            # SLOT 00/device/block/sdb
            #
            block_dir = os.path.join(
                slot_path,
                "device",
                "block",
            )

            if not os.path.isdir(block_dir):
                continue

            try:

                devices = os.listdir(
                    block_dir
                )

            except OSError:
                continue

            if not devices:
                continue

            dev = "/dev/" + devices[0]

            #
            # Extract slot number
            #
            slot_match = re.search(
                r"(\d+)",
                slot_name,
            )

            if not slot_match:
                continue

            slot_num = int(
                slot_match.group(1)
            )

            mapping[enclosure][slot_num] = dev

            debug(
                f"Enclosure map: "
                f"{enclosure} "
                f"slot {slot_num} "
                f"-> {dev}"
            )

    return mapping

def map_sg_to_enclosure():

    mapping = {}

    enclosure_root = "/sys/class/enclosure"

    if not os.path.isdir(enclosure_root):
        return mapping

    for enclosure in os.listdir(enclosure_root):

        enclosure_link = os.path.realpath(
            os.path.join(
                enclosure_root,
                enclosure,
            )
        )

        #
        # Strip trailing /enclosure/<name>
        #
        enclosure_parent = os.path.dirname(
            os.path.dirname(
                enclosure_link
            )
        )

        for sg in os.listdir(
            "/sys/class/scsi_generic"
        ):

            sg_path = os.path.realpath(
                f"/sys/class/scsi_generic/{sg}/device"
            )

            if sg_path == enclosure_parent:

                mapping[f"/dev/{sg}"] = enclosure

                debug(
                    f"SG map: "
                    f"/dev/{sg} -> {enclosure}"
                )

    debug(f"SG map: {mapping}")

    return mapping

#############################################################################
# LED State
#############################################################################


def get_locate_led_state(backplane, slot):

    output = sysexec(f"sg_ses -I {slot} --get=ident {backplane}").strip()

    if output == "1":
        return "On"

    if output == "0":
        return "Off"

    return "Unknown"

#############################################################################
# Mapping Functions
#############################################################################


def map_sas_to_dev():

    """
    Return map of Linux WWN/SAS -> /dev node
    """

    debug("map_sas_to_dev()")

    mapping = {}

    output_saslist = sysexec("ls -alh /dev/disk/by-id")

    for line in output_saslist.splitlines():

        if not re.search("wwn-", line):
            continue

        if re.search("part", line):
            continue

        try:

            this_dev = line.split()[-1]
            this_dev = this_dev.split("/")[-1]
            this_dev = "/dev/" + this_dev

            this_dev = canonicalize_dev(
                this_dev
            )

            this_sas = line.split()[-3]
            this_sas = this_sas.split("-")[1]
            this_sas = this_sas.split("x")[1]

            this_sas = this_sas.lower()

            debug(
                f"map_sas_to_dev(): "
                f"{this_sas} -> {this_dev}"
            )

            mapping[this_sas] = this_dev

        except Exception as exc:

            debug(
                f"map_sas_to_dev() parse failed: "
                f"{line} ({exc})"
            )

    return mapping


def map_sas_to_rid():

    """
    Return Linux WWN/SAS -> RID mapping.
    """

    debug("map_sas_to_rid()")

    mapping = {}

    #
    # Build dev -> RID map
    #
    dev_to_rid = {}

    output = sysexec("ls -alh /dev/disk/by-label")

    for line in output.splitlines():

        if "rid-data-" not in line:
            continue

        try:

            dev = line.split()[-1]
            dev = "/dev/" + dev.split("/")[-1]

            #
            # Strip partition suffix
            #
            dev = re.sub(
                r"[0-9]+$",
                "",
                dev,
            )

            dev = canonicalize_dev(dev)

            rid = line.split()[-3]
            rid = rid.split("-")[2]

            dev_to_rid[dev] = rid

            debug(
                f"RID map: "
                f"{dev} -> {rid}"
            )

        except Exception as exc:

            debug(
                f"RID parse failed: "
                f"{line} ({exc})"
            )

    #
    # Build SAS -> DEV map
    #
    sas_to_dev = map_sas_to_dev()

    #
    # Direct matches
    #
    for sas_addr, dev in sas_to_dev.items():

        if dev in dev_to_rid:

            mapping[sas_addr] = dev_to_rid[dev]

            debug(
                f"SAS direct map: "
                f"{sas_addr} -> "
                f"{dev_to_rid[dev]}"
            )

            continue

        #
        # Multipath fallback:
        # compare WWIDs
        #
        try:

            base = os.path.basename(dev)

            dev_wwid = sysexec(f"cat /sys/block/{base}/device/wwid").strip()

            if (
                not dev_wwid
                or dev_wwid == "ERROR"
            ):
                continue

            for candidate_dev, candidate_rid in (
                dev_to_rid.items()
            ):

                candidate_base = os.path.basename(
                    candidate_dev
                )

                candidate_wwid = sysexec(f"cat /sys/block/{candidate_base}/device/wwid").strip()

                if (
                    not candidate_wwid
                    or candidate_wwid == "ERROR"
                ):
                    continue

                if dev_wwid == candidate_wwid:

                    mapping[sas_addr] = candidate_rid

                    debug(
                        f"SAS multipath map: "
                        f"{sas_addr} -> "
                        f"{candidate_rid} "
                        f"({dev} == "
                        f"{candidate_dev})"
                    )

                    break

        except Exception as exc:

            debug(
                f"Multipath compare failed: "
                f"{dev} ({exc})"
            )

    return mapping, dev_to_rid


def map_backplane_slot_to_sas(backplanes):
    debug("map_backplane_slot_to_sas()")
    mapping = {}

    for this_backplane in backplanes:
        mapping[this_backplane] = {}
        output_sgses = sysexec(f"sg_ses -p aes {this_backplane}")

        current_type = None
        val_slot = None
        val_sas = None

        for line in output_sgses.splitlines():
            line = line.strip()
            if not line:
                continue

            # Track the current "Element type" section
            type_match = re.search(r"Element type:\s+(.+?)(?:,|$)", line)
            if type_match:
                current_type = type_match.group(1).strip()

            # Skip lines that aren't relevant to our parsing logic
            if not re.search(r"Element index:", line) and not re.search(r"SAS address:", line):
                continue
            if re.search(r"attached SAS address", line):
                continue

            if re.search(r"Element index:", line):
                val_slot = line.split(":")[1].strip()
                val_slot = val_slot.split(" ")[0]

            if re.search(r"SAS address:", line):
                val_sas = line.split(":")[1].strip()
                val_sas = val_sas.replace(" ", "")
                val_sas = re.sub(r"^0x", "", val_sas).lower()

            if val_slot and val_sas:
                # ✅ Only process mappings for Array device slots
                if current_type == "Array device slot":
                    debug(f"{this_backplane} slot {val_slot} -> {val_sas}")
                    mapping[this_backplane][val_slot] = val_sas

                # Reset for next element block
                val_slot = None
                val_sas = None

    return mapping


def map_backplane_slot_to_dev(
    all_backplanes,
):

    """
    Return:
        backplane/slot -> dev
        backplane/slot -> sas
    """

    debug("map_backplane_slot_to_dev()")

    mapping = {}

    backplane_slot_to_sas = (
        map_backplane_slot_to_sas(all_backplanes)
    )

    #
    # Linux WWN -> device
    #
    linux_sas_to_dev = map_sas_to_dev()

    enclosure_slot_map = (
        map_enclosure_slot_to_dev()
    )

    sg_to_enclosure = (
        map_sg_to_enclosure()
    )

    for backplane in all_backplanes:

        mapping[backplane] = {}

        all_slots = sorted(
            int(x)
            for x in (
                backplane_slot_to_sas
                .get(backplane, {})
                .keys()
            )
        )

        for slot in all_slots:

            dev = "Empty_Slot"

            ses_sas = (
                backplane_slot_to_sas
                .get(backplane, {})
                .get(str(slot))
            )

            if (
                ses_sas
                and ses_sas != "0"
            ):

                linux_sas = normalize_sas_for_linux(
                    ses_sas
                )

                #
                # Preferred:
                # SAS WWN mapping
                #
                if linux_sas in linux_sas_to_dev:

                    dev = linux_sas_to_dev[
                        linux_sas
                    ]

                #
                # Fallback:
                # Linux enclosure mapping
                #
                else:

                    enclosure = (
                        sg_to_enclosure.get(backplane)
                    )

                    if enclosure:

                        dev = (
                            enclosure_slot_map
                            .get(enclosure, {})
                            .get(slot, "Empty_Slot")
                        )

                        debug(
                            f"Enclosure fallback: "
                            f"{backplane} -> "
                            f"{enclosure} "
                            f"slot {slot} "
                            f"-> {dev}"
                        )

            mapping[backplane][slot] = dev

    return mapping, backplane_slot_to_sas

#############################################################################
# Main
#############################################################################


def main():

    get_sas_controller()

    backplane_list = find_backplanes()

    (
        backplane_slot_to_dev,
        backplane_slot_to_sas,
    ) = map_backplane_slot_to_dev(
        backplane_list,
    )

    sas_to_rid, dev_to_rid = map_sas_to_rid()

    linux_sas_to_dev = map_sas_to_dev()

#    dev_to_rid = map_dev_to_rid()

    mapped_devices = set()

    #
    # Normal SES-visible slots
    #
    for backplane in backplane_list:

        alias = backplane_list[backplane]["Alias"]

        all_slots = sorted(
            int(x)
            for x in (
                backplane_slot_to_sas
                .get(backplane, {})
                .keys()
            )
        )

        for slot in all_slots:

            dev = (
                backplane_slot_to_dev
                .get(backplane, {})
                .get(slot, "Empty_Slot")
            )

            sas = (
                backplane_slot_to_sas
                .get(backplane, {})
                .get(str(slot))
            )

            rid = "Empty"

            #
            # Preferred:
            # SAS -> RID
            #
            if sas and sas != "0":

                normalized_sas = normalize_sas_for_linux(
                    sas
                )

                rid = sas_to_rid.get(
                    normalized_sas,
                    "Empty",
                )

            #
            # Fallback:
            # DEV -> RID
            #
            if rid == "Empty" and dev != "Empty_Slot":

                rid = dev_to_rid.get(
                    canonicalize_dev(dev),
                    "Empty",
                )

                if rid != "Empty":

                    debug(
                        f"RID device fallback: "
                        f"{dev} -> {rid}"
                    )

            #
            # Skip phantom SES elements
            #
            #if (
            #    sas != "0"
            #    and dev == "Empty_Slot"
            #    and rid == "Empty"
            #):
            #    continue

            #
            # Track mapped devices
            #
            if dev != "Empty_Slot":
                mapped_devices.add(dev)

            #
            # Skip LED queries on empty bays
            #
            if sas == "0":

                led_state = "-"

            else:

                led_state = get_locate_led_state(
                    backplane,
                    slot,
                )

            OUTPUT.append([
                alias,
                str(slot),
                led_state,
                dev,
                rid,
            ])

    #
    # Add rotational Linux drives
    # not visible in SES
    #
    for sas_addr, dev in sorted(
        linux_sas_to_dev.items()
    ):

        #
        # Already mapped into enclosure
        #
        if dev in mapped_devices:
            continue

        #
        # Ignore SSD/NVMe/flash devices
        #
        if not is_rotational_drive(dev):

            debug(
                f"Skipping non-rotational "
                f"unmapped drive: {dev}"
            )

            continue

        rid = sas_to_rid.get(
            sas_addr,
            "Empty",
        )

        OUTPUT.append([
            "Unmapped",
            "?",
            "?",
            dev,
            rid,
        ])


    #
    # Remove duplicates and sort
    #
    output_unique = sorted(
        set(tuple(x) for x in OUTPUT)
    )

    table = PrettyTable([
        "Backplane",
        "Slot",
        "Locate LED",
        "Dev",
        "RID",
    ])

    table.padding_width = 1
    table.align = "l"

    for row in output_unique:
        table.add_row(row)

    print(table)


if __name__ == "__main__":
    main()
